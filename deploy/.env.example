# Copy this file to `.env` and edit as needed:
#   cp .env.example .env
#
# Most settings (database, admin login, deployment mode) are set to sensible
# defaults in docker-compose.yml. The values below are the ones you should
# review before running in anything other than a local trial.

# External port the app is served on (http://your-host:DYFF_PORT)
DYFF_PORT=3000

# ----- Secrets -----
# Replace with long random strings for any non-trial deployment. Generate with:
#   openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string
LLM_KEY_ENCRYPTION_SECRET=change-me-to-another-long-random-string
