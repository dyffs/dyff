# --- Generated by setup.sh; safe to edit by hand ---

# Image to pull. Pin to a specific tag in production.
DYFF_IMAGE=dyffs/dyff:latest

# External port the app is served on (http://your-host:DYFF_PORT)
DYFF_PORT=3000

# Public URL where the app is reached. Used for OAuth callbacks, CORS, etc.
FRONTEND_URL=http://localhost:3000

# ----- Deployment mode -----
DEPLOYMENT_MODE=self_hosted

# ----- Secrets (auto-generated by setup.sh, change at your own risk) -----
JWT_SECRET=change-me-to-a-long-random-string
LLM_KEY_ENCRYPTION_SECRET=change-me-to-another-long-random-string

# ----- Database (bundled postgres by default) -----
DB_HOST=postgres
DB_PORT=5432
DB_USER=dyff
DB_PASSWORD=change-me
DB_NAME=dyff

# ----- Redis (bundled by default) -----
REDIS_HOST=redis
REDIS_PORT=6379

# ----- Self-hosted admin bootstrap -----
SELF_HOST_ADMIN_EMAIL=admin@dyff.local
SELF_HOST_ADMIN_PASSWORD=changeme

# ----- Optional: GitHub App (SaaS-style integration) -----
# Leave blank to use PAT-based GitHub access only.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_SLUG=
GITHUB_APP_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=

# ----- Optional: third-party tools -----
EXA_API_KEY=

# ----- Optional: egress proxy (Squid) -----
# Set by setup.sh when the user enables outbound whitelisting.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,postgres,redis
